<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>English-Luganda Translator</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1DB954 0%, #1ed760 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 30px 80px rgba(29, 185, 84, 0.25);
            max-width: 900px;
            width: 100%;
            overflow: hidden;
        }

        header {
            background: linear-gradient(135deg, #1DB954 0%, #1ed760 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
            border-bottom: 5px solid #ffffff;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            font-weight: 700;
            letter-spacing: 1px;
        }

        header p {
            font-size: 1.1em;
            opacity: 0.95;
            font-weight: 500;
        }

        .status-badge {
            display: inline-block;
            background: rgba(255, 255, 255, 0.3);
            padding: 8px 16px;
            border-radius: 25px;
            margin-top: 12px;
            font-size: 0.9em;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .status-badge.ready {
            background: #ffffff;
            color: #1DB954;
        }

        .content {
            padding: 40px;
        }

        /* Info Box */
        .info-box {
            background: linear-gradient(135deg, #f0fff4 0%, #e6fffa 100%);
            color: #22a84b;
            padding: 18px;
            border-radius: 12px;
            margin-bottom: 30px;
            border-left: 5px solid #1DB954;
            font-size: 0.95em;
            line-height: 1.6;
        }

        .info-box strong {
            color: #1DB954;
            font-size: 1.05em;
        }
        .translator-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 25px;
        }

        .input-group {
            display: flex;
            flex-direction: column;
        }

        .input-group label {
            font-size: 1em;
            font-weight: 700;
            margin-bottom: 10px;
            color: #1DB954;
            letter-spacing: 0.5px;
        }

        textarea {
            width: 100%;
            min-height: 150px;
            padding: 16px;
            border: 2px solid #e0f2e0;
            border-radius: 12px;
            font-size: 0.95em;
            font-family: inherit;
            resize: vertical;
            transition: all 0.3s;
            background: white;
            color: #333;
        }

        textarea:hover {
            border-color: #1DB954;
        }

        textarea:focus {
            outline: none;
            border-color: #1DB954;
            box-shadow: 0 0 0 4px rgba(29, 185, 84, 0.15);
            background: #ffffff;
        }

        textarea::placeholder {
            color: #bbb;
        }

        textarea[readonly] {
            background: #f8fff5;
            color: #333;
            border-color: #e0f2e0;
        }

        .char-count {
            font-size: 0.8em;
            color: #1DB954;
            margin-top: 6px;
            font-weight: 600;
        }

        /* Tabs Styling */
        .tab-btn {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            border: 2px solid transparent;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            font-size: 0.95em;
        }

        .tab-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            border-color: white;
        }

        .tab-btn.active {
            background: white;
            color: #1DB954;
            border-color: white;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Voice Buttons */
        .voice-buttons {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .btn-voice {
            background: #0066ff;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9em;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-voice:hover {
            background: #0052cc;
            transform: translateY(-2px);
        }

        .btn-voice:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        /* Phrasebook Styles */
        .phrasebook-category {
            background: white;
            padding: 20px;
            margin: 10px 0;
            border-radius: 12px;
            border-left: 5px solid #1DB954;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .phrasebook-category h3 {
            color: #1DB954;
            margin-bottom: 15px;
            font-size: 1.2em;
        }

        .phrase-item {
            background: #f9f9f9;
            padding: 12px;
            margin: 8px 0;
            border-radius: 8px;
            border-left: 3px solid #1ed760;
            cursor: pointer;
            transition: all 0.3s;
        }

        .phrase-item:hover {
            background: #f0fff4;
            transform: translateX(5px);
        }

        .phrase-english {
            font-weight: 700;
            color: #333;
            margin-bottom: 5px;
        }

        .phrase-luganda {
            color: #1DB954;
            font-size: 0.95em;
            margin-bottom: 5px;
        }

        .phrase-context {
            font-size: 0.85em;
            color: #888;
            font-style: italic;
        }

        /* History Styles */
        .history-list {
            max-height: 500px;
            overflow-y: auto;
        }

        .history-item {
            background: white;
            padding: 15px;
            margin: 10px 0;
            border-radius: 10px;
            border-left: 4px solid #1DB954;
            box-shadow: 0 2px 6px rgba(0,0,0,0.1);
        }

        .history-timestamp {
            font-size: 0.85em;
            color: #999;
            margin-bottom: 8px;
        }

        .history-text {
            font-weight: 600;
            color: #333;
            margin-bottom: 5px;
        }

        .history-translation {
            color: #1DB954;
            margin-bottom: 5px;
        }

        /* Stats */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #f0fff4 0%, #e6fffa 100%);
            padding: 20px;
            border-radius: 12px;
            border-left: 5px solid #1DB954;
            text-align: center;
        }

        .stat-number {
            font-size: 2em;
            font-weight: 700;
            color: #1DB954;
        }

        .stat-label {
            color: #666;
            font-size: 0.95em;
            margin-top: 5px;
        }

        .button-group {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 12px;
            margin-bottom: 30px;
        }

        button {
            padding: 14px 20px;
            border: none;
            border-radius: 10px;
            font-size: 0.95em;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 0.5px;
        }

        .btn-translate {
            background: linear-gradient(135deg, #1DB954 0%, #1ed760 100%);
            color: white;
            font-size: 1em;
            box-shadow: 0 6px 16px rgba(29, 185, 84, 0.3);
        }

        .btn-translate:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 24px rgba(29, 185, 84, 0.4);
        }

        .btn-translate:active {
            transform: translateY(-1px);
        }

        .btn-translate:active {
            transform: translateY(0);
        }

        .btn-translate:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-clear {
            background: #f5f5f5;
            color: #333;
        }

        .btn-clear:hover {
            background: #e0e0e0;
        }

        .btn-copy {
            background: #4caf50;
            color: white;
        }

        .btn-copy:hover {
            background: #45a049;
        }

        .loading-spinner {
            display: none;
            width: 16px;
            height: 16px;
            border: 2px solid #f3f3f3;
            border-top: 2px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-right: 8px;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .translate-button-content {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-message {
            display: none;
            background: #ffebee;
            color: #d32f2f;
            padding: 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            border-left: 5px solid #d32f2f;
            font-size: 0.95em;
            font-weight: 600;
        }

        .success-message {
            display: none;
            background: #e8f5e9;
            color: #1DB954;
            padding: 16px;
            border-radius: 10px;
            margin-bottom: 20px;
            border-left: 5px solid #1DB954;
            font-size: 0.95em;
            font-weight: 600;
        }

        .info-box {
            background: #e8f4f8;
            color: #004d73;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 15px;
            border-left: 4px solid #0088cc;
            font-size: 0.85em;
            line-height: 1.4;
        }

        .examples-section {
            background: linear-gradient(135deg, #f0fff4 0%, #ffffff 100%);
            padding: 30px;
            border-radius: 15px;
            margin-top: 25px;
            border: 2px solid #e0f2e0;
        }

        .examples-section h3 {
            font-size: 1.3em;
            margin-bottom: 20px;
            color: #1DB954;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .examples-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
        }

        .example-item {
            background: white;
            padding: 16px;
            border-radius: 10px;
            border-left: 5px solid #1DB954;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 2px 8px rgba(29, 185, 84, 0.1);
        }

        .example-item:hover {
            transform: translateX(5px) translateY(-2px);
            box-shadow: 0 8px 20px rgba(29, 185, 84, 0.2);
            border-left: 5px solid #1ed760;
        }

        .example-text {
            font-weight: 700;
            color: #1DB954;
            margin-bottom: 3px;
            font-size: 0.95em;
        }

        .example-translation {
            font-size: 0.85em;
            color: #666;
            line-height: 1.4;
        }

        footer {
            background: linear-gradient(135deg, #f8fff5 0%, #ffffff 100%);
            padding: 25px;
            text-align: center;
            color: #1DB954;
            font-size: 0.9em;
            line-height: 1.6;
            border-top: 2px solid #e0f2e0;
            font-weight: 600;
        }

        @media (max-width: 600px) {
            .container {
                max-width: 100%;
                border-radius: 10px;
            }

            header h1 {
                font-size: 1.4em;
            }

            header p {
                font-size: 0.85em;
            }

            .content {
                padding: 15px;
            }

            .language-bar {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .translator-section {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            textarea {
                min-height: 100px;
            }

            .button-group {
                grid-template-columns: 1fr;
            }

            .examples-list {
                grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>English-Luganda Translator</h1>
            <p>Instant Translation Between English and Luganda</p>
            <div class="status-badge ready" id="statusBadge">
                Ready to Translate
            </div>
            
            <!-- Tabs Navigation -->
            <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;">
                <button class="tab-btn active" onclick="switchTab('translator')">🌐 Translator</button>
                <button class="tab-btn" onclick="switchTab('phrasebook')">📚 Phrasebook</button>
                <button class="tab-btn" onclick="switchTab('history')">📊 History</button>
            </div>
        </header>

        <div class="content">
            <div id="errorMessage" class="error-message"></div>
            <div id="successMessage" class="success-message"></div>
            
            <!-- TRANSLATOR TAB -->
            <div id="translator" class="tab-content active">
                <div class="info-box">
                    <strong>How It Works:</strong><br/>
                    • <strong>Dictionary:</strong> 128+ verified cultural phrases<br/>
                    • <strong>AI Model:</strong> For new sentences<br/>
                    • <strong>Clans:</strong> All 22 Baganda clans recognized
                </div>

                <!-- Translation Boxes -->
                <div class="translator-section">
                    <div class="input-group">
                        <label>English Text</label>
                        <textarea id="sourceText" placeholder="Type English text here..." maxlength="1000"></textarea>
                        <div class="char-count">
                            <span id="sourceCount">0</span>/1000 characters
                        </div>
                        <div class="voice-buttons">
                            <button class="btn-voice" id="micBtn" title="Speak (voice input)">🎤 Speak</button>
                            <button class="btn-voice" id="speakSourceBtn" title="Listen to English">🔊 Listen</button>
                        </div>
                    </div>

                    <div class="input-group">
                        <label>Luganda Translation</label>
                        <textarea id="targetText" placeholder="Luganda translation will appear here..." maxlength="1000" readonly></textarea>
                        <div class="char-count">
                            <span id="targetCount">0</span>/1000 characters
                        </div>
                        <div class="voice-buttons">
                            <button class="btn-voice" id="speakTargetBtn" title="Listen to Luganda">🔊 Listen</button>
                            <button class="btn-voice" id="copyTranslateBtn">📋 Copy</button>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="button-group">
                    <button class="btn-translate" id="translateBtn">
                        <div class="translate-button-content">
                            <span class="loading-spinner" id="spinner"></span>
                            <span id="btnText">Translate Now</span>
                        </div>
                    </button>
                    <button class="btn-clear" id="clearBtn">Clear</button>
                    <button class="btn-copy" id="copyBtn">Copy</button>
                </div>

                <!-- Examples -->
                <div class="examples-section">
                    <h3>Popular Examples</h3>
                    <div class="examples-list" id="examplesList"></div>
                </div>
            </div>

            <!-- PHRASEBOOK TAB -->
            <div id="phrasebook" class="tab-content">
                <h2 style="color: #1DB954; margin-bottom: 20px;">📚 Luganda Learning Mode</h2>
                <p style="color: #666; margin-bottom: 20px;">Learn common Luganda phrases organized by category. Click any phrase to translate it.</p>
                <div id="phrasebookContent"></div>
            </div>

            <!-- HISTORY TAB -->
            <div id="history" class="tab-content">
                <h2 style="color: #1DB954; margin-bottom: 20px;">📊 Translation History & Analytics</h2>
                <div class="stats-container" id="statsContainer"></div>
                <button class="btn-clear" id="clearHistoryBtn" style="margin-bottom: 20px;">Clear History</button>
                <div class="history-list" id="historyList"></div>
            </div>
        </div>

        <footer>
            <p>Powered by Helsinki-NLP OPUS-MT | AI Translation Technology</p>
            <p>© 2024 English-Luganda Translator | Built for Cultural Exchange</p>
        </footer>
    </div>

    <script>
        // ============================================================================
        // TAB MANAGEMENT
        // ============================================================================
        function switchTab(tabName) {
            // Hide all tabs
            document.querySelectorAll('.tab-content').forEach(tab => {
                tab.classList.remove('active');
            });
            
            // Remove active from all buttons
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Show selected tab
            document.getElementById(tabName).classList.add('active');
            
            // Mark button as active
            event.target.classList.add('active');
            
            // Load content for specific tabs
            if (tabName === 'phrasebook') {
                loadPhrasebook();
            } else if (tabName === 'history') {
                loadHistory();
                loadStats();
            }
        }

        // ============================================================================
        // DOM Elements
        // ============================================================================
        const sourceText = document.getElementById('sourceText');
        const targetText = document.getElementById('targetText');
        const translateBtn = document.getElementById('translateBtn');
        const clearBtn = document.getElementById('clearBtn');
        const copyBtn = document.getElementById('copyBtn');
        const spinner = document.getElementById('spinner');
        const btnText = document.getElementById('btnText');
        const sourceCount = document.getElementById('sourceCount');
        const targetCount = document.getElementById('targetCount');
        const errorMessage = document.getElementById('errorMessage');
        const successMessage = document.getElementById('successMessage');
        const examplesList = document.getElementById('examplesList');
        const micBtn = document.getElementById('micBtn');
        const speakSourceBtn = document.getElementById('speakSourceBtn');
        const speakTargetBtn = document.getElementById('speakTargetBtn');
        const copyTranslateBtn = document.getElementById('copyTranslateBtn');
        const clearHistoryBtn = document.getElementById('clearHistoryBtn');

        // ============================================================================
        // CHARACTER COUNT (Source box only - target is auto-filled)
        // ============================================================================
        sourceText.addEventListener('input', () => {
            sourceCount.textContent = sourceText.value.length;
        });

        // ============================================================================
        // CLEAR & COPY
        // ============================================================================
        clearBtn.addEventListener('click', () => {
            sourceText.value = '';
            targetText.value = '';
            sourceCount.textContent = '0';
            targetCount.textContent = '0';
            hideMessages();
        });

        copyBtn.addEventListener('click', () => {
            // Copy whichever box has more text or last was edited
            const text = targetText.value || sourceText.value;
            if (text) {
                navigator.clipboard.writeText(text).then(() => {
                    showSuccess('Copied to clipboard!');
                });
            }
        });

        copyTranslateBtn.addEventListener('click', () => {
            // Copy from target box
            if (targetText.value) {
                navigator.clipboard.writeText(targetText.value).then(() => {
                    showSuccess('Copied to clipboard!');
                });
            } else if (sourceText.value) {
                navigator.clipboard.writeText(sourceText.value).then(() => {
                    showSuccess('Copied to clipboard!');
                });
            }
        });

        // ============================================================================
        // TEXT-TO-SPEECH
        // ============================================================================
        speakSourceBtn.addEventListener('click', async () => {
            if (!sourceText.value) {
                showError('Please enter text to listen to');
                return;
            }
            
            try {
                speakSourceBtn.disabled = true;
                const response = await fetch('/api/speak', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({text: sourceText.value, language: 'en'})
                });
                
                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const audio = new Audio(url);
                audio.play();
            } catch (error) {
                showError('Text-to-speech error: ' + error.message);
            } finally {
                speakSourceBtn.disabled = false;
            }
        });

        speakTargetBtn.addEventListener('click', async () => {
            if (!targetText.value) {
                showError('Please translate text first');
                return;
            }
            
            try {
                speakTargetBtn.disabled = true;
                const response = await fetch('/api/speak', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({text: targetText.value, language: 'lg'})
                });
                
                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const audio = new Audio(url);
                audio.play();
            } catch (error) {
                showError('Text-to-speech error: ' + error.message);
            } finally {
                speakTargetBtn.disabled = false;
            }
        });
            } finally {
                speakSourceBtn.disabled = false;
            }
        });

        speakTargetBtn.addEventListener('click', async () => {
            if (!targetText.value) {
                showError('Please translate first');
                return;
            }
            
            try {
                speakTargetBtn.disabled = true;
                const lang = targetLanguage.value === 'english' ? 'en' : 'lg';
                const response = await fetch('/api/speak', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({text: targetText.value, language: lang})
                });
                
                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const audio = new Audio(url);
                audio.play();
            } catch (error) {
                showError('Text-to-speech error: ' + error.message);
            } finally {
                speakTargetBtn.disabled = false;
            }
        });

        // ============================================================================
        // TRANSLATE FUNCTION (Manual button)
        // ============================================================================
        async function translate() {
            const text = sourceText.value.trim();

            if (!text) {
                showError('Please enter some text to translate');
                return;
            }

            translateBtn.disabled = true;
            spinner.style.display = 'inline-block';
            btnText.textContent = 'Translating...';
            hideMessages();

            try {
                const sourceLang = sourceLanguage.value;
                const targetLang = targetLanguage.value;

                const response = await fetch('/api/translate', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ 
                        text: text,
                        source_language: sourceLang,
                        target_language: targetLang
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    targetText.value = data.translation;
                    targetCount.textContent = data.translation.length;
                    const source = data.in_dictionary ? 'Dictionary' : 'AI Model';
                    const confidence = data.in_dictionary ? 'Verified' : 'Experimental';
                    showSuccess(`${source} | ${confidence}`);
                } else {
                    showError('Translation failed: ' + data.error);
                }
            } catch (error) {
                showError('Error: ' + error.message);
            } finally {
                translateBtn.disabled = false;
                spinner.style.display = 'none';
                btnText.textContent = 'Translate Now';
            }
        }

        // Manual translate button click
        translateBtn.addEventListener('click', translate);

        // Also allow Ctrl+Enter in either box to manually translate
        sourceText.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'Enter') {
                translate();
            }
        });

        targetText.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'Enter') {
                translate();
            }
        });

        // ============================================================================
        // MESSAGE DISPLAY
        // ============================================================================
        function showError(message) {
            errorMessage.textContent = message;
            errorMessage.style.display = 'block';
            successMessage.style.display = 'none';
        }

        function showSuccess(message) {
            successMessage.textContent = message;
            successMessage.style.display = 'block';
            errorMessage.style.display = 'none';
        }

        function hideMessages() {
            errorMessage.style.display = 'none';
            successMessage.style.display = 'none';
        }

        // ============================================================================
        // EXAMPLES
        // ============================================================================
        function setExample(text) {
            sourceText.value = text;
            sourceCount.textContent = sourceText.value.length;
            autoTranslateFromSource();
        }

        async function loadExamples() {
            try {
                const response = await fetch('/api/examples');
                const data = await response.json();
                const examples = data.examples || [];

                examplesList.innerHTML = examples.map(ex => `
                    <div class="example-item" onclick="setExample('${ex.english.replace(/'/g, "\\'")}')" title="Click to translate">
                        <div class="example-text">${ex.english}</div>
                        <div class="example-translation">→ ${ex.luganda}</div>
                    </div>
                `).join('');
            } catch (error) {
                console.error('Error loading examples:', error);
                examplesList.innerHTML = '<p style="color: #999; padding: 10px;">Could not load examples</p>';
            }
        }

        // ============================================================================
        // PHRASEBOOK FEATURE
        // ============================================================================
        async function loadPhrasebook() {
            try {
                const response = await fetch('/api/phrasebook');
                const data = await response.json();
                const phrasebook = data.phrasebook || {};

                const content = document.getElementById('phrasebookContent');
                content.innerHTML = Object.entries(phrasebook).map(([category, phrases]) => `
                    <div class="phrasebook-category">
                        <h3>${category}</h3>
                        ${phrases.map(p => `
                            <div class="phrase-item" onclick="learnPhrase('${p.english.replace(/'/g, "\\'")}')">
                                <div class="phrase-english">🇬🇧 ${p.english}</div>
                                <div class="phrase-luganda">🇺🇬 ${p.luganda}</div>
                                <div class="phrase-context">📖 ${p.cultural_context}</div>
                            </div>
                        `).join('')}
                    </div>
                `).join('');
            } catch (error) {
                console.error('Error loading phrasebook:', error);
            }
        }

        function learnPhrase(englishText) {
            document.getElementById('translator').classList.add('active');
            document.getElementById('phrasebook').classList.remove('active');
            document.querySelectorAll('.tab-btn')[0].classList.add('active');
            document.querySelectorAll('.tab-btn')[1].classList.remove('active');
            
            sourceText.value = englishText;
            sourceCount.textContent = englishText.length;
            autoTranslateFromSource();
        }

        // ============================================================================
        // HISTORY & ANALYTICS
        // ============================================================================
        async function loadHistory() {
            try {
                const response = await fetch('/api/history?limit=20');
                const data = await response.json();
                const history = data.history || [];

                const historyList = document.getElementById('historyList');
                if (history.length === 0) {
                    historyList.innerHTML = '<p style="color: #999; padding: 20px; text-align: center;">No translations yet</p>';
                } else {
                    historyList.innerHTML = history.map((h, i) => `
                        <div class="history-item">
                            <div class="history-timestamp">${new Date(h.timestamp).toLocaleString()}</div>
                            <div class="history-text">🇬🇧 ${h.source_text}</div>
                            <div class="history-translation">🇺🇬 ${h.target_text}</div>
                        </div>
                    `).join('');
                }
            } catch (error) {
                console.error('Error loading history:', error);
            }
        }

        async function loadStats() {
            try {
                const response = await fetch('/api/history/stats');
                const data = await response.json();

                const statsContainer = document.getElementById('statsContainer');
                statsContainer.innerHTML = `
                    <div class="stat-card">
                        <div class="stat-number">${data.total_translations}</div>
                        <div class="stat-label">Total Translations</div>
                    </div>
                    ${data.most_translated.slice(0, 2).map((item, i) => `
                        <div class="stat-card">
                            <div class="stat-number">${item.count}</div>
                            <div class="stat-label">"${item.phrase.substring(0, 20)}..."</div>
                        </div>
                    `).join('')}
                `;
            } catch (error) {
                console.error('Error loading stats:', error);
            }
        }

        clearHistoryBtn.addEventListener('click', async () => {
            if (confirm('Clear all translation history?')) {
                try {
                    const response = await fetch('/api/history/clear', {method: 'POST'});
                    const data = await response.json();
                    showSuccess('History cleared!');
                    loadHistory();
                    loadStats();
                } catch (error) {
                    showError('Error clearing history');
                }
            }
        });

        // ============================================================================
        // INITIALIZE
        // ============================================================================
        loadExamples();
    </script>
</body>
</html>
