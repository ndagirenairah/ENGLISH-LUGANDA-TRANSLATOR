# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Model Configuration
MODEL_PATH=./models/trained_model
DEVICE=cuda
MAX_INPUT_LENGTH=512
MAX_OUTPUT_LENGTH=256

# API Configuration
MAX_BATCH_SIZE=50
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Server Configuration
WORKERS=4
THREADS=2
TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
